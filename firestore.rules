// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    // CATALOGS
    match /catalogs/{id} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // PRODUCTS
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ORDERS
    match /orders/{id} {
      allow read: if isAuth() && (resource.data.resellerUid == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // WITHDRAWALS
    match /withdrawals/{id} {
      allow read: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // CLIENTS
    match /clients/{id} {
      allow read, write: if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuth();
    }

    // NOTIFICATIONS
    match /notifications/{id} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // ANALYTICS (read only for owners)
    match /analytics/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // SETTINGS (admin only)
    match /settings/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // REFERRALS
    match /referrals/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }
  }
}
